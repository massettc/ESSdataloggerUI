[Unit]
Description=ESS Datalogger PLC Cloud Alarm
After=network-online.target pi-network-admin.service
Wants=network-online.target

[Service]
Type=simple
User=pi-network-admin
Group=pi-network-admin
WorkingDirectory=/opt/pi-network-admin
EnvironmentFile=/etc/pi-network-admin/app.env
ExecStart=/opt/pi-network-admin/.venv/bin/python plc_alarm.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target