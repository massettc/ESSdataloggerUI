PI_ADMIN_SECRET_KEY=change-me-before-deploy
PI_ADMIN_HOST=0.0.0.0
PI_ADMIN_PORT=8080
PI_ADMIN_NAME=ESS Datalogger UI
PI_ADMIN_WIFI_INTERFACE=wlan0
PI_ADMIN_ETHERNET_INTERFACE=eth0
PI_ADMIN_PRIMARY_INTERFACE=wlan0
PI_ADMIN_BACKUP_INTERFACE=eth0
PI_ADMIN_PRIMARY_CONNECTION_NAME=
PI_ADMIN_BACKUP_CONNECTION_NAME=
PI_ADMIN_NMCLI_BIN=nmcli
PI_ADMIN_USE_SUDO_FOR_NMCLI=true
PI_ADMIN_GIT_BIN=git
PI_ADMIN_DOCKER_BIN=docker
PI_ADMIN_BASH_BIN=bash
PI_ADMIN_SUDO_BIN=sudo
PI_ADMIN_HOSTNAMECTL_BIN=hostnamectl
PI_ADMIN_SYSTEMCTL_BIN=systemctl
PI_ADMIN_USE_SUDO_FOR_SYSTEM=true
PI_ADMIN_USE_SUDO_FOR_DOCKER=true
PI_ADMIN_PORTAINER_CONTAINER_NAME=portainer
PI_ADMIN_PORTAINER_HTTP_PORT=9000
PI_ADMIN_PORTAINER_HTTPS_PORT=9443
PI_ADMIN_PORTAINER_HOSTNAME=
PI_ADMIN_MQTT_UI_HOSTNAME=
PI_ADMIN_MQTT_UI_PORT=
PI_ADMIN_REPO_PATH=/opt/pi-network-admin
PI_ADMIN_UPDATE_SCRIPT=/opt/pi-network-admin/deploy/update-from-git.sh
PI_ADMIN_UPDATE_LOG_PATH=/var/log/pi-network-admin/update.log
PI_ADMIN_UPDATE_STATUS_FILE=/opt/pi-network-admin/update-status.txt
PI_ADMIN_TECHNICIAN_COMMANDS_FILE=/etc/pi-network-admin/technician_commands.json
PI_ADMIN_TECHNICIAN_OUTPUT_FILE=/var/log/pi-network-admin/technician-output.json
PI_ADMIN_JSON_EDITOR_PATHS=
PI_ADMIN_TECHNICIAN_COMMAND_PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PI_ADMIN_TECHNICIAN_COMMAND_TIMEOUT_SECONDS=300
PI_ADMIN_PING_BIN=ping
PI_ADMIN_COMMAND_TIMEOUT_SECONDS=15
PI_ADMIN_VERIFY_TIMEOUT_SECONDS=30
PI_ADMIN_VERIFY_POLL_SECONDS=2
PI_ADMIN_WATCHDOG_ENABLED=true
PI_ADMIN_WATCHDOG_TARGET_HOST=1.1.1.1
PI_ADMIN_WATCHDOG_INTERVAL_SECONDS=10
PI_ADMIN_WATCHDOG_PING_TIMEOUT_SECONDS=2
PI_ADMIN_WATCHDOG_FAILURE_THRESHOLD=3
PI_ADMIN_WATCHDOG_RECOVERY_THRESHOLD=2
PI_ADMIN_PREFER_WLAN_FOR_INTERNET=true
PI_ADMIN_PRIMARY_ROUTE_METRIC=100
PI_ADMIN_BACKUP_ROUTE_METRIC=600
PI_ADMIN_LOG_PATH=/var/log/pi-network-admin/app.log
PI_ADMIN_PASSWORD_HASH_FILE=/etc/pi-network-admin/admin_password.hash
PI_ADMIN_SECURE_COOKIE=false
