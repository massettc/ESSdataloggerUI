# Allow the service account to run limited network, docker, and system actions without a password.
# Adjust the paths if commands are installed elsewhere on the target image.
pi-network-admin ALL=(root) NOPASSWD: /usr/bin/nmcli, /usr/bin/hostnamectl, /usr/bin/systemctl, /usr/bin/git, /usr/bin/docker, /usr/bin/systemd-run, /usr/bin/tee /var/usr/plcreader/settings.json, /usr/bin/tee /etc/pi-network-admin/*.json, /usr/bin/tee /opt/opsviewer/opsviewer-env.json, /usr/bin/tee /etc/NetworkManager/system-connections/*, /usr/bin/chmod 600 /etc/NetworkManager/system-connections/*, /bin/chmod 600 /etc/NetworkManager/system-connections/*, /usr/local/sbin/pi-network-admin-set-hostname *, /usr/bin/bash /opt/pi-network-admin/deploy/update-from-git.sh *, /bin/bash /opt/pi-network-admin/deploy/update-from-git.sh *, /usr/bin/bash /opt/pi-network-admin/deploy/set-hostname.sh *, /bin/bash /opt/pi-network-admin/deploy/set-hostname.sh *, /usr/bin/bash /opt/pi-network-admin/deploy/opsviewer-redeploy.sh *, /bin/bash /opt/pi-network-admin/deploy/opsviewer-redeploy.sh *, /usr/bin/bash /opt/pi-network-admin/deploy/install.sh, /bin/bash /opt/pi-network-admin/deploy/install.sh, /usr/bin/ip link set * address *, /sbin/ip link set * address *, /usr/sbin/ip link set * address *, /usr/bin/ip link set * down, /sbin/ip link set * down, /usr/sbin/ip link set * down, /usr/bin/tee /etc/systemd/system/pi-network-admin-eth-mac.service, /usr/bin/systemctl daemon-reload, /usr/bin/systemctl enable pi-network-admin-eth-mac.service, /usr/bin/systemctl disable pi-network-admin-eth-mac.service
# Allow the pi admin user full passwordless sudo (mirrors the Raspberry Pi OS default).
pi ALL=(ALL) NOPASSWD: ALL
