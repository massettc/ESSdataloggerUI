# Allow the service account to run limited network and system actions without a password.
# Adjust the paths if commands are installed elsewhere on the target image.
pi-network-admin ALL=(root) NOPASSWD: /usr/bin/nmcli, /usr/bin/hostnamectl, /usr/bin/systemctl, /usr/bin/git, /usr/bin/bash /opt/pi-network-admin/deploy/update-from-git.sh *
